# Copy to .env and adjust. Every value below is optional - shown defaults
# match the hardcoded behavior if you don't set anything.

# STATEMENTS_DIR=statements
# REPORTS_DIR=reports

# DPI used to render PDF pages to images for OCR (Liverpool always, Banamex
# fallback rows). Higher = slower but more accurate on small/blurry text.
# OCR_DPI=300

# strict (default): a totals-reconciliation mismatch blocks import (❌).
# warn-only (false/0/warn): same checks run and print, but never block (⚠️).
# VALIDATION_STRICT=true
